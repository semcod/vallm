# Docker Client Test for MCP Vallm Integration
FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements
COPY pyproject.toml .
COPY README.md .

# Install vallm and dependencies
RUN pip install --no-cache-dir -e .

# Copy source code
COPY src/ ./src/
COPY mcp/ ./mcp/

# Make test executable
RUN chmod +x mcp/tests/test_client_integration.py

# Default command - will be overridden by docker-compose
CMD ["python3", "-c", "print('MCP Client ready')"]
